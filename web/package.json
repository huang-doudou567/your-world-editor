    "jszip": "^3.10.1",
    "lucide-react": "^1.21.0",
    "openai": "^6.45.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.0",
    "recharts": "^3.9.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.19.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
